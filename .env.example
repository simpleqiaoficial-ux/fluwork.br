# Conexão Postgres (Cloud SQL, IP privado em produção)
DATABASE_URL=postgresql://usuario:senha@host:5432/fluxopay

# Bucket do Google Cloud Storage usado para notas fiscais e faturas
GCS_BUCKET_NAME=fluworkbr-documents

# Padrão do Next.js — "production" em produção
NODE_ENV=development

# Módulo de Contratos — Resend (e-mail) e URL base pra montar o link de assinatura
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_ADMIN_NOTIFY_EMAIL=
APP_BASE_URL=http://localhost:3000
